eclipse.preferences.version=1
prefWatchExpressions=<?xml version\="1.0" encoding\="UTF-8" standalone\="no"?>\r\n<watchExpressions>\r\n    <expression enabled\="true" text\="i"/>\r\n    <expression enabled\="true" text\="input[i]"/>\r\n    <expression enabled\="true" text\="str.charAt(j)"/>\r\n    <expression enabled\="true" text\="word"/>\r\n    <expression enabled\="true" text\="input"/>\r\n    <expression enabled\="true" text\="input.length"/>\r\n    <expression enabled\="true" text\="input.length-1"/>\r\n    <expression enabled\="true" text\="input.length-1-i"/>\r\n    <expression enabled\="true" text\="[input.length-1-i]"/>\r\n</watchExpressions>\r\n
